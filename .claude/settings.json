{
  "$schema": "https://code.claude.com/settings.schema.json",
  "_comment": "\u30ef\u30fc\u30af\u30b7\u30e7\u30c3\u30d7\u5b89\u5168\u8a2d\u5b9a\uff08DCP\u6e96\u62e0\uff09\u3002\u53c2\u52a0\u8005\u306e\u5b89\u5168\u3092\u5b88\u308b\u305f\u3081\u306e\u8a2d\u5b9a\u3002",
  "_tiers": "deny=Tier1(\u7d76\u5bfe\u7981\u6b62\u30fb\u30d6\u30ed\u30c3\u30af), ask=Tier3(\u78ba\u8a8d\u5fc5\u9808\u30fb\u30a2\u30e9\u30fc\u30c8), allow=Tier4(\u901a\u5e38\u64cd\u4f5c\u30fb\u81ea\u52d5\u8a31\u53ef)",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(npm test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run build:*)"
    ],
    "ask": [
      "Write",
      "Edit",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(npm install:*)",
      "Bash(docker:*)",
      "Bash(rm:*)",
      "Bash(rm -r:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rmdir:*)",
      "Bash(unlink:*)",
      "Bash(find * -delete*)",
      "Bash(rsync * --delete*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(shred:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git remote set-url:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(.secrets/**)",
      "Read(credentials/**)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(.secrets/**)",
      "Write(credentials/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(.secrets/**)",
      "Edit(credentials/**)",
      "Read(~/.ssh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.config/gh/**)",
      "Edit(~/.zshrc)",
      "Write(~/.zshrc)",
      "Edit(~/.bashrc)",
      "Write(~/.bashrc)",
      "WebFetch"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false
  }
}
